# eProcurement System — Environment Variables
# Copy to .env and fill in all values before starting

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://eprocure_user:CHANGE_ME@postgres:5432/eprocure
POSTGRES_DB=eprocure
POSTGRES_USER=eprocure_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (generate with: openssl rand -hex 32) ─────────────────
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Provider Key Encryption ─────────────────────────────────
# Separate from JWT_SECRET — rotating JWTs won't break stored AI keys
# Generate with: openssl rand -hex 32
AI_ENCRYPTION_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# ── Security ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Storage ────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30
MAX_FILE_SIZE=10485760

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info

# ── App URL (used in email links) ──────────────────────────────
APP_URL=https://yourdomain.com

# ── SMTP Email ─────────────────────────────────────────────────
# Configure via Admin UI → System Settings → Email after first login.
# These env vars are only used as bootstrap — settings DB takes precedence.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=SolarProcure
SMTP_FROM_EMAIL=noreply@yourdomain.com
